# Demo-инстанс CRM. Этот файл — шаблон. На сервере положить как .env.demo
# рядом с demo_start.sh и заполнить настоящими (демо-)значениями.

# Включает роуты /dev_auth/* (выбор роли без пароля).
DEBUG=1

# Отключает обычный /auth/login. Для demo обязательно: единственный путь входа — dev_auth.
FIL_DEV_AUTH_ONLY=1

# Внешние API: для demo не использовать настоящие ключи. Worker мы не запускаем,
# но даже если кто-то ткнёт ручку — секретов нет, никаких реальных интеграций.
TG_API_ID=
TG_API_HASH=
MORELOGIN_TOKEN=
CURRENCY_API_KEY=
